          },
          "editorMode": "code",
          "expr": "sum by (tier) (count_over_time({service=\"delegate-local\", source=\"delegate\"} | json | project=~\"$project\" [$__auto]))",
          "queryType": "range",
          "legendFormat": "{{tier}}"
        }
      ]
