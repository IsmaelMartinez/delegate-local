  "timepicker": {},
  "refresh": "",
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "textbox",
        "label": "delegate.project",
        "description": "Repo filter on the delegate.project field. Default .* matches all repos; type an exact name like delegate-local or a regex like repoA|repoB.",
        "query": ".*",
        "current": {
          "selected": true,
          "text": ".*",
          "value": ".*"
        },
        "options": [
          {
            "selected": true,
            "text": ".*",
            "value": ".*"
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 14,
      "type": "stat",
      "title": "Errors",
      "description": "Delegations with non-zero exit_status.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [],
          "color": {
            "mode": "thresholds",
            "fixedColor": "text"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum(count_over_time({service=\"delegate-local\", source=\"delegate\"} | json | project=~\"$project\" | exit_status!=\"0\" [$__range]))",
          "queryType": "instant"
        }
      ]
    },
