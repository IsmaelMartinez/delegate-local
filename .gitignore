.DS_Store
*.log
*.tmp
__pycache__/
.venv/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Per-user telemetry written by scripts/delegate.sh. The default metrics path
# is $HOME/.claude/skills/delegate-local/metrics.jsonl, which resolves
# through the `npx skills add`-installed symlink back to the repo root for
# anyone developing the skill while it's installed. The file is private to
# the user and never belongs in git. The trailing-dot glob also covers the
# timestamped backups (e.g. metrics.jsonl.bak-20260525) left behind by hand.
metrics.jsonl
metrics.jsonl.*

# Per-user overrides written by scripts/onboard.sh (or the init.sh /
# derive-flavor.sh redirects). Same symlink-resolution story as metrics.jsonl
# above: the default paths land in the repo root for anyone developing the
# skill while it's installed. Private to the user, never in git; the .bak
# glob covers onboard.sh's timestamped pre-overwrite backups.
/config.sh
/config.sh.bak*
/profile.sh
/profile.sh.bak*

# Per-cell patched source trees written by session scorers (e.g. scorer-v8.py).
# Regenerated on every scorer run; the raw model outputs in v*-runs/ are the
# source of truth, the patched trees are an intermediate artefact.
experiments/sessions/**/v*-patched/

# Per-run trigger-eval result files (one JSONL per scoring run, timestamped).
# The directory is kept for tooling discoverability via .gitkeep, but the
# raw run outputs are local-only — re-runnable on demand.
evals/results/*.jsonl
